{
  "name": "@luzilab.epsinyx/epsi-edt",
  "version": "0.1.0",
  "description": "Un système de scrapping de l'EDT Reseau CD",
  "main": "index.node",
  "scripts": {
    "build": "cargo-cp-artifact -nc index.node -- cargo build --message-format=json-render-diagnostics",
    "build-debug": "npm run build --",
    "build-release": "npm run build -- --release",
    "install": "npm run build-release",
    "test": "cargo test"
  },
  "author": "Louis DUCRUET",
  "license": "ISC",
  "devDependencies": {
    "cargo-cp-artifact": "^0.1"
  },
  "keywords": [
    "scrapping",
    "rust",
    "edt"
  ]
}